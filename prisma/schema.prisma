generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  profession    String?
  licenseNumber String?
  plan          Plan          @default(FREE)
  role          Role          @default(THERAPIST)
  specialty     Specialty     @default(CLINICAL_PSYCHOLOGY)
  isActive      Boolean       @default(true)
  locale        String        @default("es")
  createdAt     DateTime      @default(now())
  patients      Patient[]
  feedbacks     Feedback[]
  featureFlags  FeatureFlag[]
}

model Patient {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  firstName        String
  lastName         String
  email            String?
  phone            String?
  birthDate        DateTime?
  gender           String?
  referredBy       String?
  startDate        DateTime         @default(now())
  status           PatientStatus    @default(ACTIVE)
  emergencyContact String?
  createdAt        DateTime         @default(now())
  deletedAt        DateTime?
  clinicalProfile  ClinicalProfile?
  sessions         Session[]
  appointments     Appointment[]
  documents        Document[]
  goals            Goal[]
  reports          Report[]

  @@index([userId])
}

model ClinicalProfile {
  id                 String          @id @default(cuid())
  patientId          String          @unique
  patient            Patient         @relation(fields: [patientId], references: [id])
  consultationReason String?
  background         String?
  currentMedication  String?
  previousTherapy    String?
  actValues          String?
  disabilityType     DisabilityType?
  autonomyLevel      String?
  integrationContext String?
  updatedAt          DateTime        @updatedAt
}

model Session {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  date            DateTime
  duration        Int           @default(50)
  sessionNumber   Int
  status          SessionStatus @default(COMPLETED)
  notes           String?
  nextSessionGoal String?
  paymentStatus   PaymentStatus @default(PENDING)
  paymentAmount   Float?
  meetLink        String?
  meetProvider    MeetProvider?
  createdAt       DateTime      @default(now())
  deletedAt       DateTime?

  @@index([patientId])
}

model Appointment {
  id           String            @id @default(cuid())
  patientId    String
  patient      Patient           @relation(fields: [patientId], references: [id])
  scheduledAt  DateTime
  status       AppointmentStatus @default(CONFIRMED)
  reminderSent Boolean           @default(false)
  createdAt    DateTime          @default(now())

  @@index([patientId])
}

model Document {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  name       String
  url        String
  type       String   @default("OTHER")
  uploadedAt DateTime @default(now())

  @@index([patientId])
}

model Feedback {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  type            FeedbackType
  title           String
  description     String
  currentBehavior String?
  desiredBehavior String?
  priority        Priority       @default(MEDIUM)
  status          FeedbackStatus @default(NEW)
  screenshotUrl   String?
  createdAt       DateTime       @default(now())

  @@index([userId])
}

enum Plan {
  FREE
  PRO
}

enum PatientStatus {
  ACTIVE
  PAUSED
  DISCHARGED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PAID
  PENDING
  EXEMPT
}

enum AppointmentStatus {
  CONFIRMED
  PENDING
  CANCELLED
}

enum FeedbackType {
  BUG
  FEATURE_REQUEST
  IMPROVEMENT
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum FeedbackStatus {
  NEW
  SEEN
  IN_PROGRESS
  DONE
}

enum Role {
  THERAPIST
  ADMIN
}

enum MeetProvider {
  GOOGLE_MEET
  ZOOM
  TEAMS
  OTHER
}

enum FeatureFlagScope {
  GLOBAL
  PER_USER
}

enum Specialty {
  CLINICAL_PSYCHOLOGY
  SOCIAL_INTEGRATION
}

enum GoalArea {
  SOCIAL
  LABOR
  EDUCATIONAL
  FAMILY
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  ACHIEVED
}

enum ProgressScale {
  INITIAL
  IN_DEVELOPMENT
  ACHIEVED
}

enum ReportArea {
  SOCIAL_INTEGRATION
  LABOR_INTEGRATION
  EDUCATIONAL_INTEGRATION
  FAMILY_INTEGRATION
  AUTONOMY
}

enum DisabilityType {
  MOTOR
  COGNITIVE
  SENSORY
  MULTIPLE
  OTHER
}

model Goal {
  id          String     @id @default(cuid())
  patientId   String
  patient     Patient    @relation(fields: [patientId], references: [id])
  description String
  area        GoalArea
  status      GoalStatus @default(PENDING)
  targetDate  DateTime?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([patientId])
}

model Report {
  id              String        @id @default(cuid())
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  area            ReportArea
  progressScale   ProgressScale
  observations    String
  recommendations String
  nextObjectives  String
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([patientId])
}

model FeatureFlag {
  id        String           @id @default(cuid())
  key       String
  enabled   Boolean          @default(false)
  scope     FeatureFlagScope @default(GLOBAL)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([key, userId])
}
